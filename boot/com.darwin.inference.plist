<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.darwin.inference</string>
    <key>ProgramArguments</key>
    <array>
        <string>__DARWIN_ROOT__/boot/run_inference.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>WorkingDirectory</key>
    <string>__DARWIN_ROOT__</string>
    <key>StandardOutPath</key>
    <string>__DARWIN_ROOT__/state/logs/launchd-inference.log</string>
    <key>StandardErrorPath</key>
    <string>__DARWIN_ROOT__/state/logs/launchd-inference.log</string>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
